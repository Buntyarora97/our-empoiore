# Copy this file to .env and fill in your values

# Your Render API URL (after deploying the API server to Render)
# Option A: Use EXPO_PUBLIC_API_URL (recommended for production)
EXPO_PUBLIC_API_URL=https://our-empire-api.onrender.com

# Option B: Use EXPO_PUBLIC_DOMAIN (legacy, uses https://{domain})
EXPO_PUBLIC_DOMAIN=our-empire-api.onrender.com

# WhatsApp support number (with country code, no + sign)
# Example: India +91 98765 43210 → 919876543210
EXPO_PUBLIC_WHATSAPP_NUMBER=919999999999

# Telegram channel/group link
EXPO_PUBLIC_TELEGRAM_LINK=https://t.me/ourempire
